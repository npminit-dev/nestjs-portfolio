# Contact Form Configuration
# Copy this to .env and fill in your actual values

# Email settings (for sending form submissions)
CONTACT_EMAIL_USER=your-email@example.com
CONTACT_EMAIL_PASSWORD=your-email-password
CONTACT_EMAIL_FROM=noreply@example.com
CONTACT_EMAIL_TO=jorgeb.dev.acc@gmail.com

# Optional: SMTP configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false